<Window x:Class="WpfMathApp.Pages.Page3"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        Title="Страница 3 — Табуляция y"
        Height="780" Width="860"
        WindowStartupLocation="CenterScreen"
        Background="#F0F4F8">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="30,20" MaxWidth="800">

            <TextBlock Text="Табуляция функции y = ax³ + cos²(x³ − b)"
                       FontSize="20" FontWeight="Bold"
                       Foreground="#2C3E50" Margin="0,0,0,16"/>

            <Border Background="White" CornerRadius="8" Padding="16" Margin="0,0,0,20"
                    BorderBrush="#DDE1E7" BorderThickness="1">
                <Image Source="/Images/formula3.png" Stretch="Uniform" MaxHeight="100"/>
            </Border>

            <Border Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,16"
                    BorderBrush="#DDE1E7" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="42"/>
                        <RowDefinition Height="42"/>
                        <RowDefinition Height="42"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="42"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="160"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="42"/>
                    </Grid.RowDefinitions>

                    <Label Grid.Row="0" Grid.Column="0" Content="x₀ =" FontWeight="SemiBold"/>
                    <TextBox x:Name="Input_X0" Grid.Row="0" Grid.Column="1" Text="-1.5" VerticalAlignment="Center"/>
                    <Label Grid.Row="0" Grid.Column="3" Content="xk =" FontWeight="SemiBold"/>
                    <TextBox x:Name="Input_Xk" Grid.Row="0" Grid.Column="4" Text="10.3" VerticalAlignment="Center"/>

                    <Label Grid.Row="1" Grid.Column="0" Content="dx =" FontWeight="SemiBold"/>
                    <TextBox x:Name="Input_Dx" Grid.Row="1" Grid.Column="1" Text="0.25" VerticalAlignment="Center"/>

                    <Label Grid.Row="2" Grid.Column="0" Content="a =" FontWeight="SemiBold"/>
                    <TextBox x:Name="Input_A" Grid.Row="2" Grid.Column="1" Text="1.35" VerticalAlignment="Center"/>
                    <Label Grid.Row="2" Grid.Column="3" Content="b =" FontWeight="SemiBold"/>
                    <TextBox x:Name="Input_B" Grid.Row="2" Grid.Column="4" Text="-6.25" VerticalAlignment="Center"/>

                    <Label Grid.Row="4" Grid.Column="0" Content="Ответ" FontWeight="SemiBold" Foreground="#27AE60"/>
                    <TextBox x:Name="Result" Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="4"
                             IsReadOnly="True" Background="#F8FFF8"
                             BorderBrush="#27AE60" VerticalAlignment="Center"/>

                    <Label Grid.Row="6" Grid.Column="0" Content="Таблица:" FontWeight="SemiBold"
                           VerticalAlignment="Top" Margin="0,4,0,0"/>
                    <TextBox x:Name="Table" Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="4"
                             IsReadOnly="True" Background="#F8FFF8"
                             BorderBrush="#27AE60"
                             TextWrapping="NoWrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas" FontSize="12"/>

                    <StackPanel Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="5"
                                Orientation="Horizontal" HorizontalAlignment="Left">
                        <Button Content="Вычислить" Style="{StaticResource ModernButton}"
                                Click="Calculate" Margin="0,0,12,0"/>
                        <Button Content="Очистить" Style="{StaticResource ClearButton}"
                                Click="Clear"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Background="White" CornerRadius="8" Padding="16" Margin="0,0,0,20"
                    BorderBrush="#DDE1E7" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="График функции" FontSize="15" FontWeight="SemiBold"
                               Foreground="#2C3E50" Margin="0,0,0,10"/>
                    <lvc:CartesianChart x:Name="Chart" Height="280" LegendLocation="Right">
                        <lvc:CartesianChart.AxisX>
                            <lvc:Axis Title="x" x:Name="AxisX">
                                <lvc:Axis.Separator>
                                    <lvc:Separator StrokeThickness="0.5" StrokeDashArray="4"
                                                   Stroke="#EEEEEE"/>
                                </lvc:Axis.Separator>
                            </lvc:Axis>
                        </lvc:CartesianChart.AxisX>
                        <lvc:CartesianChart.AxisY>
                            <lvc:Axis Title="y">
                                <lvc:Axis.Separator>
                                    <lvc:Separator StrokeThickness="0.5" StrokeDashArray="4"
                                                   Stroke="#EEEEEE"/>
                                </lvc:Axis.Separator>
                            </lvc:Axis>
                        </lvc:CartesianChart.AxisY>
                    </lvc:CartesianChart>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Window>
