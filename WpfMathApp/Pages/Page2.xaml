<Window x:Class="WpfMathApp.Pages.Page2"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Страница 2 — Функция d"
        Height="530" Width="700"
        WindowStartupLocation="CenterScreen"
        Background="#F0F4F8">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="30,20" MaxWidth="640">

            <TextBlock Text="Вычисление функции d"
                       FontSize="20" FontWeight="Bold"
                       Foreground="#2C3E50" Margin="0,0,0,16"/>

            <Border Background="White" CornerRadius="8" Padding="16" Margin="0,0,0,20"
                    BorderBrush="#DDE1E7" BorderThickness="1">
                <Image Source="/Images/formula2.png" Stretch="Uniform" MaxHeight="120"/>
            </Border>

            <Border Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,16"
                    BorderBrush="#DDE1E7" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="240"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="42"/>
                        <RowDefinition Height="42"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="42"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="42"/>
                    </Grid.RowDefinitions>

                    <Label Grid.Row="0" Grid.Column="0" Content="x =" FontWeight="SemiBold"/>
                    <TextBox x:Name="Input_X" Grid.Row="0" Grid.Column="1" VerticalAlignment="Center"/>

                    <Label Grid.Row="1" Grid.Column="0" Content="y =" FontWeight="SemiBold"/>
                    <TextBox x:Name="Input_Y" Grid.Row="1" Grid.Column="1" VerticalAlignment="Center"/>

                    <Label Grid.Row="3" Grid.Column="0" Content="f(x):" FontWeight="SemiBold"
                           VerticalAlignment="Top" Margin="0,4,0,0"/>
                    <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Vertical">
                        <RadioButton x:Name="Radio_Sh" Content="sh(x) — гиперболический синус" IsChecked="True"/>
                        <RadioButton x:Name="Radio_X2" Content="x²"/>
                        <RadioButton x:Name="Radio_Ex" Content="eˣ"/>
                    </StackPanel>

                    <Label Grid.Row="5" Grid.Column="0" Content="Ответ" FontWeight="SemiBold" Foreground="#27AE60"/>
                    <TextBox x:Name="Result" Grid.Row="5" Grid.Column="1"
                             IsReadOnly="True" Background="#F8FFF8"
                             BorderBrush="#27AE60" VerticalAlignment="Center"/>

                    <StackPanel Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2"
                                Orientation="Horizontal" HorizontalAlignment="Left">
                        <Button Content="Вычислить" Style="{StaticResource ModernButton}"
                                Click="Calculate" Margin="0,0,12,0"/>
                        <Button Content="Очистить" Style="{StaticResource ClearButton}"
                                Click="Clear"/>
                    </StackPanel>
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Window>
